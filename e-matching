#### e-matching for baseline:
type Subst = PVar -> GId;

# initially called with g = refl.
ematch(g*x: GId, pat, subst) -> Vec<Subst> {
    if let ?v = pat {
        if let Some(g2*x2) = subst[?v] {
            if !eq(g*x, g2*x2) { return Vec::new() }
        } else {
            subst.insert(?v, g*x);
        }
        return vec![subst]
    }

    out = [];
    for g2*node in x {
        if !eq(g*x, g2*x) { continue }
        if node.op != pat.op { continue }

        let f(a1, ..., an) = node;
        let f(p1, ..., pn) = pat;

        matches = [subst];
        for i in 1..n {
            for subst in std::mem::take(&mut matches) {
                matches.extend(ematch(ai, pi, subst));
            }
        }
        out.extend(matches);
    }
    out
}


#### skeleton e-matching: Ignoring all the group annotations.
type Subst = PVar -> Id;

skel_ematch(x: Id, pat, subst) -> Vec<Subst> {
    if let ?v = pat {
        if let Some(x2) = subst[?v] {
            if x != x2 { return Vec::new() }
        } else {
            subst.insert(?v, x);
        }
        return vec![subst]
    }

    out = [];
    for _*node in x {
        if node.op != pat.op { continue }

        let f(a1, ..., an) = node;
        let f(p1, ..., pn) = pat;

        matches = [subst];
        for i in 1..n {
            for subst in std::mem::take(&mut matches) {
                matches.extend(skel_ematch(ai, pi, subst));
            }
        }
        out.extend(matches);
    }
    out
}
