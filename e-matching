# Some pseudocode thoughts on e-matching

#### e-matching for proofs (via skeleton):

type Subst = PVar -> Id;

# `[(g, subst), ...] = ematch(x, pat)` means `g*x = pat[subst]`
ematch(x: Id, pat) -> Vec<(G, Subst)> {
    out = [];
    for subst in skel_ematch(x, pat, []) {
        let g*x' = instantiate(pat, subst);
        assert(x == x');
        out.push((g, subst));
    }
    out
}

# `g*x = instantiate(pat, subst)` means `g*x = pat[subst]`
instantiate(pat, subst) -> GId {
    match pat {
        ?p => subst[?p],
        f(p1, ..., pn) => {
            let node = f(instantiate(p1, subst), ..., instantiate(pn, subst));
            lookup(node)
        },
    }
}

#### e-matching for proofs:

type Subst = PVar -> Id; # we don't want GIds here necessarily, even though it wouldn't be criminal to have them, as we consider any G a self-loop in this.
ematch(x: Id, pat, subst) -> Vec<(G, Subst)> {
    if let ?v = pat {
        if let Some(x2) = subst[?v] {
            if x != x2 { return Vec::new() }
        } else {
            subst.insert(?v, x);
        }
        return vec![(refl, subst)]
    }

    out = [];
    for g'*node in x {
        if node.op != pat.op { continue }

        let f(refl*a1, ..., refl*an) = node; # by canonization we know these are refl.
        let f(p1, ..., pn) = pat;

        matches = [(refl, subst)];
        for i in 1..n {
            for (g_s, subst) in std::mem::take(&mut matches) {
                for (g_inner, subst_new) in ematch(ai, pi, subst) {
                    real_g = proj(g_inner, i, n) * g_s
                    matches.push((real_g, subst_new))
                }
            }
        }
        for (gg, subst) in matches {
            out.push((g'*gg, subst));
        }
    }
    out
}

# This could entirely replace cong also.
proj(g, i: num, n: num) {
    cong(refl, ..., g, ..., refl)
    #               |         |
    #          at index i    length n
}

